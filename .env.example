# Project paths for Google Colab.
PROJECT_DIR=/content/drive/MyDrive/KITTI_Road_UNet
KITTI_ROAD_ROOT=/content/drive/MyDrive/KITTI_Road_UNet/data/data_road
KITTI_PROCESSED_DIR=/content/drive/MyDrive/KITTI_Road_UNet/data/processed/kitti_road
REPORT_DIR=/content/drive/MyDrive/KITTI_Road_UNet/reports
