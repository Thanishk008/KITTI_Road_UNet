# Project paths for Google Colab A100.
PROJECT_DIR=/content/KITTI_Road_UNet
KITTI_ROAD_ROOT=/content/data/data_road
KITTI_PROCESSED_DIR=data/processed/kitti_road
REPORT_DIR=reports
CHECKPOINT_DIR=checkpoints

# Training defaults mirrored by configs/*.yaml.
SEED=6681
IMAGE_HEIGHT=384
IMAGE_WIDTH=1216
EPOCHS=80
BATCH_SIZE=8
NUM_WORKERS=8
LR=0.0003
WEIGHT_DECAY=0.0001
SAVE_EVERY_EPOCHS=10
THRESHOLD=0.5
AMP=true

# CUDA expectation.
REQUIRE_CUDA=true
